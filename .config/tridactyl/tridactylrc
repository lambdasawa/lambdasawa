# mode
bind I mode ignore

# cmd
bind x fillcmdline_notrail

# edit text by vscode
bind c-i editor

# move page
bind f hint
bind F hint -b
bind s hint -h

# scroll
bind j scrollline 10
bind k scrollline -10
bind G scrollto 100
bind gg scrollto 0

# find
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext -1

# tab move
bind h tabprev
bind l tabnext
bind b fillcmdline buffer

# new tab
bind o fillcmdline open
bind t fillcmdline tabopen
bind p clipboard open
bind P clipboard tabopen

# close tab
bind d tabclose

# pin tab
bind p pin

# history
bind H back
bind L forward

# reload page
bind r reload
bind R reloadhard

# zoom
bind zi zoom 0.1 true
bind zo zoom -0.1 true
bind zz zoom 1

# edit
bind e editor

# reload settings
bind ,r composite js alert('tridactylrc loading...'); source; js alert('tridactylrc loaded!')

# test js
bind ,x js alert('~/.trydactylrc loaded!')

# translate selected text to japanese
bind a translateselection
bind A translatepage

# add current page to feedly
bind ,f addfeedly

# exec git clone at github
bind ,g gitclone

# open vscode at github
bind ,e openvscode

# open github compare page
bind ,c js location.href = location.href.match(new RegExp('https://github.com/[^/]+/[^/]+'))[0] + "/compare"

# open twitter share link
bind ,t opentwitterintent

# open amazon short url
bind ,a openamazonshorturl

# exec youtube-dl
bind ,y youtubedl

################################################################################
