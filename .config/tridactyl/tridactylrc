################################################################################
#### Basic #####################################################################
################################################################################

# wipe settings
sanitize tridactyllocal tridactylsync

set hintchars jfkdhglsamvurceixwozqp

set smoothscroll true

set findcase smart

set editorcmd /opt/homebrew/bin/code --wait

set rsscmd open %u

colors my

################################################################################
#### Command ###################################################################
################################################################################

command translateselection js -r js/translateSelection.js
command translatepage js -r js/translatePage.js

command addfeedly js -r js/addfeedly.js

command gitclone js -r js/gitclone.js

command openvscode js -r js/openvscode.js

command opentwitterintent js -r js/opentwitterintent.js

command openamazonshorturl js -r js/openamazonshorturl.js

command youtubedl js -r js/youtubedl.js

command highlightcloudwatchlogs js -r js/highlightCloudWatchLogs.js

