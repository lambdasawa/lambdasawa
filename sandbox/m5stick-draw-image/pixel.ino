#include <M5StickC.h>

int convert24bitTo16bitColor(int c)
{
  int R = (c & 0xff0000) >> 8;
  int G = (c & 0x00ff00) >> 5;
  int B = (c & 0x0000ff) >> 3;

  return R + G + B;
}

