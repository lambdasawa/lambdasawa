#!/bin/bash

set -xeuo pipefail

vault=${1:?}
item=${2:?}
section=${3:?}
shell=${OPSH_SHELL:-fish}

op item get --format json --vault "$vault" "$item" |
  jq -r '.fields[] | select(.label != null and .value != null) | .label' | sed -E "s|(.+)|\1=op://${vault}/${item}/${section}/\1|" \
  >.env.op

op run --env-file .env.op --no-masking "$shell"
