#!/bin/bash

set -euo pipefail

lambda_name=${1:?}
payload=$(cat | base64)
output_path=$(mktemp)

output=$(
  aws lambda invoke \
    --function-name "$lambda_name" \
    --payload "$payload" \
    --log-type Tail \
    "$output_path"
)

jq . <"$output_path"

echo "$output" | jq -r '.LogResult | @base64d'
