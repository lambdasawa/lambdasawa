#!/bin/bash

set -e

if ! test -e ~/.voice-enable; then
  exit
fi

if [ "$1" = "Success" ] && [ -e ~/.voice/success.mp3 ]; then
    mpv ~/.voice/success.mp3 >/dev/null 2>&1
    exit $?
elif [ "$1" = "Failure" ] && [ -e ~/.voice/failure.mp3 ]; then
    mpv ~/.voice/failure.mp3 >/dev/null 2>&1
    exit $?
fi

if which say >/dev/null 2>&1; then
  say -v Victoria "$@"
  exit $?
fi
